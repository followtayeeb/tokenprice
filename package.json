{
  "name": "llm-costs",
  "version": "0.1.0",
  "description": "Know before you send. Compare LLM costs in your terminal.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "llm-costs": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:scripts": "tsc --project tsconfig.scripts.json",
    "fetch-prices": "tsx scripts/fetch-prices.ts",
    "dev": "tsc --watch --project tsconfig.json",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" --write \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm run test && npm run lint",
    "release": "npm version patch && npm publish"
  },
  "keywords": [
    "llm",
    "cost",
    "calculator",
    "cli",
    "terminal",
    "openai",
    "anthropic",
    "gpt",
    "claude",
    "tokens",
    "pricing",
    "tokens",
    "estimate",
    "budget",
    "ai",
    "machine-learning"
  ],
  "author": "followtayeeb",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@dqbd/tiktoken": "^1.0.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/followtayeeb/llm-costs.git"
  },
  "bugs": {
    "url": "https://github.com/followtayeeb/llm-costs/issues"
  },
  "homepage": "https://github.com/followtayeeb/llm-costs#readme"
}
